<header class="header">
  <a href="{{ routes.root_url }}" class="header__brand">
    <span class="header__monogram" aria-hidden="true">
      {{- section.settings.monogram -}}
      <span class="header__monogram-dot"></span>
    </span>
    <span class="header__wordmark">{{ shop.name }}</span>
  </a>

  <nav class="header__menu" aria-label="{{ 'general.navigation' | t }}">
    {% for link in section.settings.menu.links %}
      <a
        href="{{ link.url }}"
        {% if link.current %}
          class="header__menu-link--current" aria-current="page"
        {% endif %}
      >
        {{- link.title -}}
      </a>
    {% endfor %}
  </nav>

  <div class="header__utilities">
    <a href="{{ routes.search_url }}">{{ 'search.title' | t }}</a>

    {% if shop.customer_accounts_enabled %}
      <shopify-account menu="{{ section.settings.customer_account_menu }}">
        {{ 'icon-account.svg' | inline_asset_content }}
      </shopify-account>
    {% endif %}

    <a href="{{ routes.cart_url }}">{{ 'cart.title_with_count' | t: count: cart.item_count }}</a>
  </div>
</header>

{% stylesheet %}
  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding-block: 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }

  .header__brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: var(--color-foreground);
  }

  .header__brand:hover {
    color: var(--color-foreground);
  }

  .header__monogram {
    position: relative;
    width: 2.125rem;
    height: 2.125rem;
    border: 1.5px solid var(--color-foreground);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display--family);
    font-weight: 600;
    font-size: 0.875rem;
    letter-spacing: 0.02em;
  }

  .header__monogram-dot {
    position: absolute;
    bottom: -1px;
    left: 50%;
    transform: translate(-50%, 50%);
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-accent);
  }

  .header__wordmark {
    font-family: var(--font-display--family);
    font-weight: 600;
    font-size: 1.0625rem;
    letter-spacing: 0.01em;
  }

  .header__menu {
    display: flex;
    flex-wrap: wrap;
    gap: 1.875rem;
  }

  .header__menu a {
    font-size: 0.875rem;
    text-decoration: none;
    color: var(--color-text-muted);
  }

  .header__menu a:hover {
    color: var(--color-foreground);
  }

  .header__menu a.header__menu-link--current {
    color: var(--color-accent);
  }

  .header__utilities {
    display: flex;
    align-items: center;
    gap: 1.375rem;
  }

  .header__utilities a {
    font-size: 0.8125rem;
    letter-spacing: 0.04em;
    text-decoration: none;
    color: var(--color-text-muted);
  }

  .header__utilities a:hover {
    color: var(--color-foreground);
  }

  .header__utilities svg {
    width: 1.25rem;
  }

  @media (max-width: 749px) {
    .header {
      flex-wrap: wrap;
    }

    .header__menu {
      order: 3;
      width: 100%;
      gap: 1.25rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "text",
      "id": "monogram",
      "label": "t:labels.monogram",
      "default": "FR"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
