<footer class="footer">
  <div class="footer__columns">
    <div class="footer__brand">
      <p class="footer__wordmark">{{ shop.name }}</p>
      <p class="footer__tagline">{{ section.settings.tagline }}</p>
    </div>

    {% if section.settings.menu_1 != blank %}
      <nav class="footer__nav" aria-label="{{ section.settings.menu_1.title }}">
        <p class="meta-caps footer__nav-title">{{ section.settings.menu_1.title }}</p>
        {% for link in section.settings.menu_1.links %}
          {{ link.title | link_to: link.url }}
        {% endfor %}
      </nav>
    {% endif %}

    {% if section.settings.menu_2 != blank %}
      <nav class="footer__nav" aria-label="{{ section.settings.menu_2.title }}">
        <p class="meta-caps footer__nav-title">{{ section.settings.menu_2.title }}</p>
        {% for link in section.settings.menu_2.links %}
          {{ link.title | link_to: link.url }}
        {% endfor %}
      </nav>
    {% endif %}

    <div class="footer__newsletter">
      <p class="meta-caps footer__nav-title">{{ 'general.newsletter.title' | t }}</p>
      <p class="footer__newsletter-text">{{ section.settings.newsletter_text }}</p>
      {% form 'customer', class: 'footer__newsletter-form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <label for="footer-newsletter-email" class="visually-hidden">
          {{- 'general.newsletter.email' | t -}}
        </label>
        <input
          id="footer-newsletter-email"
          type="email"
          name="contact[email]"
          placeholder="{{ 'general.newsletter.placeholder' | t }}"
          required
        >
        <button type="submit" class="button footer__newsletter-submit">
          {{ 'general.newsletter.submit' | t }}
        </button>
      {% endform %}
    </div>
  </div>

  <div class="footer__bottom">
    <span class="footer__copyright">
      &copy;
      {{ 'now' | date: '%Y' }}
      {{ shop.name | link_to: routes.root_url }}
    </span>

    <div class="footer__payment">
      {% if section.settings.show_payment_icons %}
        {% for type in shop.enabled_payment_types %}
          {{ type | payment_type_svg_tag }}
        {% endfor %}
      {% endif %}
    </div>
  </div>
</footer>

{% stylesheet %}
  .footer {
    margin-top: 4rem;
    border-top: 1px solid var(--color-border);
    padding-block: 3.5rem 2.5rem;
  }

  .footer__columns {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.4fr;
    gap: 2.5rem;
  }

  .footer__wordmark {
    font-family: var(--font-display--family);
    font-weight: 600;
    font-size: 1.125rem;
  }

  .footer__tagline {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--color-text-subtle);
    margin-top: 0.625rem;
    max-width: 15rem;
  }

  .footer__nav {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer__nav-title {
    color: var(--color-text-faint);
    margin-bottom: 0.375rem;
  }

  .footer__nav a {
    font-size: 0.8125rem;
    text-decoration: none;
    color: var(--color-text-muted);
  }

  .footer__nav a:hover {
    color: var(--color-foreground);
  }

  .footer__newsletter-text {
    font-size: 0.8125rem;
    color: var(--color-text-subtle);
    margin-block: 0.625rem 0.75rem;
  }

  .footer__newsletter-form {
    display: flex;
    border: 1px solid var(--color-border-strong);
    border-radius: 3px;
    overflow: hidden;
  }

  .footer__newsletter-form input[type='email'] {
    flex: 1;
    min-width: 0;
    border: none;
    border-radius: 0;
    background: transparent;
    padding: 0.625rem 0.75rem;
    font-size: 0.8125rem;
    color: var(--color-foreground);
  }

  .footer__newsletter-form input[type='email']::placeholder {
    color: var(--color-text-faint);
  }

  .footer__newsletter-submit {
    border-radius: 0;
    padding: 0.625rem 1rem;
    font-size: 0.8125rem;
  }

  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-border);
  }

  .footer__copyright {
    font-size: 0.75rem;
    color: var(--color-text-subtle);
  }

  .footer__copyright a {
    color: var(--color-text-subtle);
  }

  .footer__payment {
    display: flex;
    gap: 0.5rem;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 749px) {
    .footer__columns {
      grid-template-columns: 1fr 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.footer",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "t:labels.tagline",
      "default": "Single-origin coffee, documented and roasted to order."
    },
    {
      "type": "link_list",
      "id": "menu_1",
      "label": "t:labels.menu"
    },
    {
      "type": "link_list",
      "id": "menu_2",
      "label": "t:labels.secondary_menu"
    },
    {
      "type": "text",
      "id": "newsletter_text",
      "label": "t:labels.newsletter_text",
      "default": "New lots and origin notes, monthly."
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "t:labels.show_payment_icons",
      "default": true
    }
  ]
}
{% endschema %}
