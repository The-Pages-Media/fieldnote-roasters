{% liquid
  assign current_variant = product.selected_or_first_available_variant

  # Preference blocks render outside the product form, so their inputs
  # attach to it via the HTML form attribute using this id.
  assign product_form_id = 'product-form-' | append: section.id

  # Primary data source: the coffee_configuration metaobject (custom.coffee_configuration).
  # Flat metafields in the custom namespace act as a fallback when no metaobject is linked.
  assign coffee_config = product.metafields.custom.coffee_configuration.value

  assign origin = product.metafields.custom.origin.value
  assign subtitle = product.metafields.custom.subtitle.value
  assign process = product.metafields.custom.process.value
  assign altitude = product.metafields.custom.altitude.value
  assign harvest = product.metafields.custom.harvest.value
  assign roast = product.metafields.custom.roast_level.value
  assign bag_type = ''

  if coffee_config
    if coffee_config.origin.value != blank
      assign origin = coffee_config.origin.value
    endif
    if coffee_config.processing_method.value != blank
      assign process = coffee_config.processing_method.value
    endif
    if coffee_config.roast_level.value != blank
      assign roast = coffee_config.roast_level.value
    endif
    if coffee_config.altitude.value != blank
      assign altitude = coffee_config.altitude.value
    endif
    if coffee_config.harvest.value != blank
      assign harvest = coffee_config.harvest.value
    endif
    assign bag_type = coffee_config.bag_type.value
  endif

  assign config_notes = coffee_config.tasting_notes.value
  assign brewing_methods = coffee_config.brewing_methods.value

  # Standard taxonomy flavors (category metafield → shopify--flavor metaobjects).
  # Second in priority: canonical labels, but no icon/color/description fields.
  assign std_flavors = product.metafields.shopify.flavor.value

  assign notes_mf = product.metafields.custom.tasting_notes
  assign notes = ''
  if notes_mf.type contains 'list'
    assign notes = notes_mf.value | join: '|'
  elsif notes_mf.value != blank
    assign notes = notes_mf.value | replace: ', ', '|' | replace: ',', '|'
  endif
  assign note_items = notes | split: '|'
%}

<nav class="meta-caps pdp-breadcrumb" aria-label="{{ 'general.breadcrumb' | t }}">
  {% if product.collections.first %}
    <a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a>
    <span aria-hidden="true">→</span>
  {% endif %}
  <span>{{ product.title }}</span>
</nav>

<div class="pdp">
  <div class="pdp__gallery">
    <div class="pdp__gallery-main">
      {% if product.featured_image %}
        {{
          product.featured_image
          | image_url: width: 1400
          | image_tag: loading: 'eager', fetchpriority: 'high', data-main-image: ''
        }}
      {% else %}
        {{ 'product-1' | placeholder_svg_tag: 'pdp__gallery-placeholder' }}
      {% endif %}
    </div>

    {% if product.images.size > 1 %}
      <div class="pdp__gallery-thumbs">
        {% for image in product.images %}
          <button
            type="button"
            class="pdp__gallery-thumb{% if forloop.first %} pdp__gallery-thumb--active{% endif %}"
            data-thumb
            data-full-src="{{ image | image_url: width: 1400 }}"
            aria-label="{{ 'products.view_image' | t: index: forloop.index }}"
          >
            {{ image | image_url: width: 300, height: 300, crop: 'center' | image_tag: loading: 'lazy' }}
          </button>
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <div class="pdp__info">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'vendor' %}
          {% liquid
            assign eyebrow_text = block.settings.text
            if eyebrow_text == blank
              assign eyebrow_text = origin
            endif
            if eyebrow_text == blank
              assign eyebrow_text = product.vendor
            endif
          %}
          {% if eyebrow_text != blank %}
            <p class="eyebrow" {{ block.shopify_attributes }}>{{ eyebrow_text }}</p>
          {% endif %}

        {% when 'title' %}
          <h1 class="pdp__title" {{ block.shopify_attributes }}>{{ product.title }}</h1>

        {% when 'subtitle' %}
          {% liquid
            assign subtitle_text = block.settings.text
            if subtitle_text == blank
              assign subtitle_text = subtitle
            endif
          %}
          {% if subtitle_text != blank %}
            <p class="pdp__subtitle" {{ block.shopify_attributes }}>{{ subtitle_text }}</p>
          {% endif %}

        {% when 'price' %}
          <p class="pdp__price" data-price {{ block.shopify_attributes }}>{{ current_variant.price | money }}</p>

        {% when 'description' %}
          {% if product.description != blank %}
            <div class="pdp__description" {{ block.shopify_attributes }}>{{ product.description }}</div>
          {% endif %}

        {% when 'tasting_notes' %}
          {% liquid
            assign override_items = block.settings.notes_override | replace: ', ', '|' | replace: ',', '|' | split: '|'
          %}
          {% if override_items.size > 0
            or config_notes.size > 0
            or std_flavors.size > 0
            or note_items.size > 0
          %}
            <div {{ block.shopify_attributes }}>
              <p class="meta-caps pdp__label">{{ block.settings.heading }}</p>
              <div class="pdp__notes">
                {% if override_items.size > 0 %}
                  {% for note in override_items %}
                    <span class="pill">{{ note | strip }}</span>
                  {% endfor %}
                {% elsif config_notes.size > 0 %}
                  {% for note in config_notes %}
                    <span
                      class="pill pdp__note-pill"
                      style="--note-color: {{ note.color.value | default: 'transparent' }}"
                    >
                      {%- if note.icon.value != blank -%}
                        <span aria-hidden="true">{{ note.icon.value }}</span>
                      {%- elsif note.color.value != blank -%}
                        <span class="pdp__note-dot" aria-hidden="true"></span>
                      {%- endif %}
                      {{ note.name.value -}}
                    </span>
                  {% endfor %}
                {% elsif std_flavors.size > 0 %}
                  {% for flavor in std_flavors %}
                    <span class="pill">{{ flavor.label.value }}</span>
                  {% endfor %}
                {% else %}
                  {% for note in note_items %}
                    <span class="pill">{{ note | strip }}</span>
                  {% endfor %}
                {% endif %}
              </div>
            </div>
          {% endif %}

        {% when 'facts' %}
          {% if process != blank or altitude != blank or harvest != blank or bag_type != blank %}
            <dl class="pdp__facts" {{ block.shopify_attributes }}>
              {% if process != blank %}
                <div class="pdp__fact">
                  <dt>{{ 'products.process' | t }}</dt>
                  <dd>{{ process }}</dd>
                </div>
              {% endif %}
              {% if altitude != blank %}
                <div class="pdp__fact">
                  <dt>{{ 'products.altitude' | t }}</dt>
                  <dd>{{ altitude }}</dd>
                </div>
              {% endif %}
              {% if harvest != blank %}
                <div class="pdp__fact">
                  <dt>{{ 'products.harvest' | t }}</dt>
                  <dd>{{ harvest }}</dd>
                </div>
              {% endif %}
              {% if bag_type != blank %}
                <div class="pdp__fact">
                  <dt>{{ 'products.packaging' | t }}</dt>
                  <dd>{{ bag_type }}</dd>
                </div>
              {% endif %}
            </dl>
          {% endif %}

        {% when 'variant_picker' %}
          {% unless product.has_only_default_variant %}
            <div {{ block.shopify_attributes }}>
              {% for option in product.options_with_values %}
                <fieldset class="pdp__option">
                  <legend class="meta-caps pdp__label">{{ option.name }}</legend>
                  <div class="pdp__option-values">
                    {% for value in option.values %}
                      <label class="pdp__option-value">
                        <input
                          type="radio"
                          name="option-{{ option.position }}"
                          value="{{ value | escape }}"
                          data-option-input
                          data-option-position="{{ option.position }}"
                          {% if value == option.selected_value %}
                            checked
                          {% endif %}
                        >
                        <span>{{ value }}</span>
                      </label>
                    {% endfor %}
                  </div>
                </fieldset>
              {% endfor %}
            </div>
          {% endunless %}

        {% when 'preference' %}
          {% liquid
            assign property_name = block.settings.property_name | strip
            assign preference_options = block.settings.options | replace: ', ', '|' | replace: ',', '|' | split: '|'
            assign preference_heading = block.settings.heading
            if preference_heading == blank
              assign preference_heading = property_name
            endif

            # Grind eligibility is assigned per product via the
            # custom.grind_options metafield (list of grind_option
            # metaobjects). The comma-separated setting is the fallback.
            assign grind_metaobjects = blank
            if block.settings.use_grind_metafield
              assign grind_metaobjects = product.metafields.custom.grind_options.value
            endif
          %}
          {% if property_name != blank %}
            {% if grind_metaobjects.size > 0 or preference_options.size > 0 %}
              <fieldset class="pdp__option pdp__preference" {{ block.shopify_attributes }}>
                <legend class="meta-caps pdp__label">{{ preference_heading }}</legend>
                <div class="pdp__option-values">
                  {% if grind_metaobjects.size > 0 %}
                    {% for grind in grind_metaobjects %}
                      <label class="pdp__option-value">
                        <input
                          type="radio"
                          name="properties[{{ property_name | escape }}]"
                          value="{{ grind.name.value | escape }}"
                          form="{{ product_form_id }}"
                          {% if forloop.first %}
                            checked
                          {% endif %}
                        >
                        <span>
                          {%- if grind.icon.value != blank -%}
                            <span aria-hidden="true">{{ grind.icon.value }}</span>
                          {% endif -%}
                          {{ grind.name.value -}}
                        </span>
                      </label>
                    {% endfor %}
                  {% else %}
                    {% for preference_option in preference_options %}
                      {% assign option_label = preference_option | strip %}
                      {% if option_label != blank %}
                        <label class="pdp__option-value">
                          <input
                            type="radio"
                            name="properties[{{ property_name | escape }}]"
                            value="{{ option_label | escape }}"
                            form="{{ product_form_id }}"
                            {% if forloop.first %}
                              checked
                            {% endif %}
                          >
                          <span>{{ option_label }}</span>
                        </label>
                      {% endif %}
                    {% endfor %}
                  {% endif %}
                </div>
                {% if block.settings.note != blank %}
                  <p class="pdp__preference-note">{{ block.settings.note }}</p>
                {% endif %}
              </fieldset>
            {% endif %}
          {% endif %}

        {% when 'buy_buttons' %}
          {% form 'product', product, id: product_form_id, class: 'pdp__form', data-product-form: '' %}
            <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id>

            <div class="pdp__buy-row" {{ block.shopify_attributes }}>
              {% if block.settings.show_quantity %}
                <div class="pdp__quantity">
                  <button type="button" data-qty-minus aria-label="{{ 'products.decrease_quantity' | t }}">–</button>
                  <input
                    type="number"
                    name="quantity"
                    value="1"
                    min="1"
                    inputmode="numeric"
                    aria-label="{{ 'products.quantity' | t }}"
                    data-qty-input
                  >
                  <button type="button" data-qty-plus aria-label="{{ 'products.increase_quantity' | t }}">+</button>
                </div>
              {% endif %}

              <button
                type="submit"
                class="button pdp__atc"
                data-atc
                data-label-add="{{ 'products.add_to_cart' | t }}"
                data-label-sold-out="{{ 'products.sold_out' | t }}"
                {% unless current_variant.available %}
                  disabled
                {% endunless %}
              >
                {%- if current_variant.available -%}
                  {{ 'products.add_to_cart' | t }} — <span data-atc-price>{{ current_variant.price | money }}</span>
                {%- else -%}
                  {{ 'products.sold_out' | t }}
                {%- endif -%}
              </button>
            </div>
          {% endform %}

        {% when 'text' %}
          {% if block.settings.text != blank %}
            <div class="pdp__text-block {{ block.settings.style }}" {{ block.shopify_attributes }}>
              {{ block.settings.text }}
            </div>
          {% endif %}

        {% when 'brewing' %}
          {% if brewing_methods.size > 0 %}
            <div {{ block.shopify_attributes }}>
              <p class="meta-caps pdp__label">{{ 'products.recommended_brewing' | t }}</p>
              <div class="pdp__brew-methods">
                {% for method in brewing_methods %}
                  <div class="pdp__brew-method">
                    <div class="pdp__brew-method-head">
                      {% if method.icon.value != blank %}
                        <span aria-hidden="true">{{ method.icon.value }}</span>
                      {% endif %}
                      <span class="pdp__brew-method-name">{{ method.name.value }}</span>
                      {% if method.brew_time.value != blank %}
                        <span class="pdp__brew-method-time">{{ method.brew_time.value }}</span>
                      {% endif %}
                    </div>
                    {% if method.description.value != blank %}
                      <p class="pdp__brew-method-description">{{ method.description.value }}</p>
                    {% endif %}
                  </div>
                {% endfor %}
              </div>
            </div>
          {% endif %}

        {% when 'accordion' %}
          <details class="pdp__accordion" {{ block.shopify_attributes }}>
            <summary>
              <span>{{ block.settings.title }}</span>
              <span class="pdp__accordion-icon" aria-hidden="true">+</span>
            </summary>
            <div class="pdp__accordion-content">{{ block.settings.content }}</div>
          </details>
      {% endcase %}
    {% endfor %}
  </div>
</div>

{% if coffee_config %}
  {% liquid
    assign note_names = ''
    for note in config_notes
      assign note_names = note_names | append: note.name.value
      unless forloop.last
        assign note_names = note_names | append: ', '
      endunless
    endfor
  %}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org/",
      "@type": "Product",
      "name": {{ product.title | json }},
      "description": {{ product.description | strip_html | json }},
      "additionalProperty": [
        { "@type": "PropertyValue", "name": "Roast level", "value": {{ roast | json }} },
        { "@type": "PropertyValue", "name": "Origin", "value": {{ origin | json }} },
        { "@type": "PropertyValue", "name": "Processing method", "value": {{ process | json }} },
        { "@type": "PropertyValue", "name": "Packaging", "value": {{ bag_type | json }} }
        {%- if note_names != blank -%}
          ,
          { "@type": "PropertyValue", "name": "Tasting notes", "value": {{ note_names | json }} }
        {%- endif %}
      ]
    }
  </script>
{% endif %}

<script type="application/json" data-variant-data>
  [
    {% for variant in product.variants %}
      {
        "id": {{ variant.id }},
        "available": {{ variant.available }},
        "options": {{ variant.options | json }},
        "price": {{ variant.price | money | json }}
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
</script>

{% stylesheet %}
  .pdp-breadcrumb {
    display: flex;
    gap: 0.5rem;
    letter-spacing: 0.1em;
    padding-block: 1.375rem 0;
  }

  .pdp-breadcrumb a {
    color: var(--color-text-subtle);
    text-decoration: none;
  }

  .pdp-breadcrumb a:hover {
    color: var(--color-foreground);
  }

  .pdp {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3.75rem;
    padding-block: 1.875rem 3.75rem;
  }

  .pdp__gallery-main {
    aspect-ratio: 1 / 1;
    border-radius: 5px;
    overflow: hidden;
    background: color-mix(in srgb, var(--color-foreground) 6%, var(--color-background));
  }

  .pdp__gallery-main img,
  .pdp__gallery-main svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .pdp__gallery-thumbs {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    margin-top: 0.75rem;
  }

  .pdp__gallery-thumb {
    aspect-ratio: 1 / 1;
    padding: 0;
    border: 1px solid transparent;
    border-radius: 3px;
    overflow: hidden;
    cursor: pointer;
    background: color-mix(in srgb, var(--color-foreground) 6%, var(--color-background));
  }

  .pdp__gallery-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .pdp__gallery-thumb--active {
    border: 1.5px solid var(--color-accent);
  }

  .pdp__title {
    font-size: clamp(2.25rem, 4vw, 2.875rem);
    line-height: 1.02;
    margin-top: 0.75rem;
  }

  .pdp__subtitle {
    font-family: var(--font-display--family);
    font-style: italic;
    font-size: 1.25rem;
    color: var(--color-text-muted);
    margin-top: 0.5rem;
  }

  .pdp__price {
    font-size: 1.625rem;
    margin-top: 1.25rem;
  }

  .pdp__description {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-text-muted);
    margin-top: 1.125rem;
  }

  .pdp__label {
    display: block;
    margin-top: 1.625rem;
  }

  .pdp__notes {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.625rem;
  }

  .pdp__note-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    border-color: color-mix(in srgb, var(--note-color) 45%, var(--color-border-strong));
    background: color-mix(in srgb, var(--note-color) 8%, transparent);
  }

  .pdp__note-dot {
    width: 0.4375rem;
    height: 0.4375rem;
    border-radius: 50%;
    background: color-mix(in srgb, var(--note-color) 80%, var(--color-foreground));
  }

  .pdp__brew-methods {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    margin-top: 0.625rem;
  }

  .pdp__brew-method {
    padding: 0.75rem 0.875rem;
    background: color-mix(in srgb, var(--color-foreground) 4%, transparent);
    border-radius: 4px;
  }

  .pdp__brew-method-head {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .pdp__brew-method-name {
    font-family: var(--font-display--family);
    font-weight: 600;
    font-size: 0.9375rem;
  }

  .pdp__brew-method-time {
    margin-left: auto;
    font-size: 0.8125rem;
    color: var(--color-text-subtle);
  }

  .pdp__brew-method-description {
    font-size: 0.8125rem;
    line-height: 1.55;
    color: var(--color-text-muted);
    margin-top: 0.25rem;
  }

  .pdp__facts {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(7rem, 1fr));
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    overflow: hidden;
    margin-block: 1.5rem 0;
  }

  .pdp__fact {
    background: var(--color-background);
    padding: 1rem 1.125rem;
  }

  .pdp__fact dt {
    font-size: 0.625rem;
    letter-spacing: var(--tracking-meta);
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .pdp__fact dd {
    font-family: var(--font-display--family);
    font-weight: 600;
    font-size: 1rem;
    margin: 0.25rem 0 0;
  }

  .pdp__option {
    border: none;
    padding: 0;
    margin: 0;
  }

  .pdp__option-values {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
    margin-top: 0.625rem;
  }

  .pdp__option-value input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .pdp__option-value span {
    display: inline-block;
    font-size: 0.8125rem;
    padding: 0.625rem 1.125rem;
    border: 1px solid var(--color-border-strong);
    border-radius: 3px;
    cursor: pointer;
    transition: border-color 150ms ease, background 150ms ease;
  }

  .pdp__option-value input:checked + span {
    background: var(--color-foreground);
    color: var(--color-background);
    border-color: var(--color-foreground);
  }

  .pdp__option-value input:focus-visible + span {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .pdp__preference-note {
    font-size: 0.75rem;
    color: var(--color-text-subtle);
    margin-top: 0.5rem;
  }

  .pdp__buy-row {
    display: flex;
    gap: 0.75rem;
    margin-top: 1.75rem;
  }

  .pdp__quantity {
    display: flex;
    align-items: stretch;
    border: 1px solid var(--color-border-strong);
    border-radius: 3px;
    overflow: hidden;
  }

  .pdp__quantity button {
    border: none;
    background: transparent;
    color: var(--color-text-muted);
    font-size: 1.125rem;
    padding: 0 1rem;
    cursor: pointer;
  }

  .pdp__quantity input {
    width: 2.5rem;
    border: none;
    border-radius: 0;
    background: transparent;
    text-align: center;
    font-size: 0.9375rem;
    color: var(--color-foreground);
    -moz-appearance: textfield;
    appearance: textfield;
  }

  .pdp__quantity input::-webkit-outer-spin-button,
  .pdp__quantity input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .pdp__atc {
    flex: 1;
    font-size: 0.9375rem;
  }

  .pdp__text-block {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-text-muted);
    margin-top: 1.125rem;
    max-width: 27.5rem;
  }

  .pdp__text-block--fine {
    font-size: 0.75rem;
    color: var(--color-text-subtle);
    margin-top: 0.875rem;
    max-width: none;
  }

  .pdp__accordion {
    border-bottom: 1px solid var(--color-border);
  }

  .pdp__accordion:first-of-type {
    margin-top: 1.75rem;
    border-top: 1px solid var(--color-border);
  }

  .pdp__accordion summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 0;
    font-family: var(--font-display--family);
    font-weight: 600;
    font-size: 0.9375rem;
    cursor: pointer;
    list-style: none;
  }

  .pdp__accordion summary::-webkit-details-marker {
    display: none;
  }

  .pdp__accordion-icon {
    color: var(--color-text-subtle);
    font-family: var(--font-primary--family);
    font-weight: 400;
    transition: transform 200ms ease;
  }

  .pdp__accordion[open] .pdp__accordion-icon {
    transform: rotate(45deg);
  }

  .pdp__accordion-content {
    padding: 0 0 1.125rem;
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--color-text-muted);
  }

  @media (max-width: 749px) {
    .pdp {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
{% endstylesheet %}

{% javascript %}
  const root = document;

  const mainImage = root.querySelector('[data-main-image]');
  root.querySelectorAll('[data-thumb]').forEach((thumb) => {
    thumb.addEventListener('click', () => {
      if (!mainImage) return;
      mainImage.removeAttribute('srcset');
      mainImage.src = thumb.dataset.fullSrc;
      root
        .querySelectorAll('[data-thumb]')
        .forEach((t) => t.classList.remove('pdp__gallery-thumb--active'));
      thumb.classList.add('pdp__gallery-thumb--active');
    });
  });

  const qtyInput = root.querySelector('[data-qty-input]');
  const qtyMinus = root.querySelector('[data-qty-minus]');
  const qtyPlus = root.querySelector('[data-qty-plus]');
  if (qtyInput && qtyMinus && qtyPlus) {
    qtyMinus.addEventListener('click', () => {
      qtyInput.value = Math.max(1, parseInt(qtyInput.value || '1', 10) - 1);
    });
    qtyPlus.addEventListener('click', () => {
      qtyInput.value = parseInt(qtyInput.value || '1', 10) + 1;
    });
  }

  const dataEl = document.querySelector('[data-variant-data]');
  const form = root.querySelector('[data-product-form]');
  if (dataEl && form) {
    const variants = JSON.parse(dataEl.textContent);
    const idInput = form.querySelector('[data-variant-id]');
    const atcButton = form.querySelector('[data-atc]');
    const priceEl = root.querySelector('[data-price]');

    const optionInputs = Array.from(root.querySelectorAll('[data-option-input]'));

    function selectedOptions() {
      const positions = [...new Set(optionInputs.map((i) => i.dataset.optionPosition))].sort();
      return positions.map((pos) => {
        const checked = optionInputs.find(
          (i) => i.dataset.optionPosition === pos && i.checked
        );
        return checked ? checked.value : null;
      });
    }

    function updateVariant() {
      const selected = selectedOptions();
      const match = variants.find((v) =>
        v.options.every((opt, index) => opt === selected[index])
      );

      if (!match) {
        atcButton.disabled = true;
        atcButton.textContent = atcButton.dataset.labelSoldOut;
        return;
      }

      idInput.value = match.id;
      if (priceEl) priceEl.textContent = match.price;

      if (match.available) {
        atcButton.disabled = false;
        atcButton.innerHTML = '';
        atcButton.append(
          document.createTextNode(atcButton.dataset.labelAdd + ' — '),
          Object.assign(document.createElement('span'), { textContent: match.price })
        );
      } else {
        atcButton.disabled = true;
        atcButton.textContent = atcButton.dataset.labelSoldOut;
      }
    }

    optionInputs.forEach((input) => input.addEventListener('change', updateVariant));
  }
{% endjavascript %}

