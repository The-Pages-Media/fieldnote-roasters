<div class="featured-collection">
  <div class="featured-collection__head">
    <h2 class="featured-collection__heading">{{ section.settings.heading }}</h2>
    {% if section.settings.collection != blank %}
      <a href="{{ section.settings.collection.url }}" class="text-link">
        {{- 'collections.view_all' | t }} →</a
      >
    {% endif %}
  </div>

  <div class="featured-collection__grid">
    {% assign featured_products = section.settings.collection.products %}
    {% for product in featured_products limit: section.settings.products_to_show %}
      {% render 'product-card', product: product, show_badge: true %}
    {% else %}
      {% for i in (1..3) %}
        <div class="product-card">
          <div class="product-card__media">
            {{ 'product-2' | placeholder_svg_tag: 'product-card__placeholder' }}
          </div>
        </div>
      {% endfor %}
    {% endfor %}
  </div>
</div>

{% stylesheet %}
  .featured-collection {
    padding-block: 4.5rem;
  }

  .featured-collection__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .featured-collection__heading {
    font-weight: 500;
    font-size: 2.125rem;
  }

  .featured-collection__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.875rem;
  }

  @media (max-width: 749px) {
    .featured-collection__grid {
      grid-template-columns: 1fr;
      gap: 2.25rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.featured_collection",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "This week's table"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:general.collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "t:labels.products_to_show",
      "min": 3,
      "max": 12,
      "step": 3,
      "default": 3
    }
  ],
  "presets": [{ "name": "t:general.featured_collection" }],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
