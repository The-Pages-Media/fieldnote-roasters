<div class="hero {{ section.settings.layout }} full-width">
  {% if section.settings.layout == 'hero--full-bleed' %}
    {% if section.settings.image %}
      <div class="hero__background">
        {{ section.settings.image | image_url: width: 2400 | image_tag: loading: 'eager', fetchpriority: 'high' }}
      </div>
    {% endif %}
    <div class="hero__scrim" aria-hidden="true"></div>
  {% endif %}

  <div class="hero__content">
    {% if section.settings.eyebrow != blank %}
      <p class="eyebrow hero__eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}

    <h1 class="hero__heading">{{ section.settings.heading }}</h1>

    {% if section.settings.text != blank %}
      <p class="hero__text">{{ section.settings.text }}</p>
    {% endif %}

    <div class="hero__actions">
      {% if section.settings.primary_cta_label != blank %}
        <a href="{{ section.settings.primary_cta_link | default: routes.all_products_collection_url }}" class="button">
          {{- section.settings.primary_cta_label -}}
        </a>
      {% endif %}
      {% if section.settings.secondary_cta_label != blank %}
        <a
          href="{{ section.settings.secondary_cta_link | default: routes.collections_url }}"
          class="button button--secondary hero__secondary-cta"
        >
          {{- section.settings.secondary_cta_label -}}
        </a>
      {% endif %}
    </div>
  </div>

  {% if section.settings.layout == 'hero--split' %}
    <div class="hero__media">
      {% if section.settings.image %}
        {{ section.settings.image | image_url: width: 1400 | image_tag: loading: 'eager', fetchpriority: 'high' }}
      {% else %}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'hero__placeholder' }}
      {% endif %}
    </div>
  {% endif %}
</div>

{% stylesheet %}
  .hero--split {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .hero--split .hero__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    padding: 5.25rem max(4rem, calc((100vw - var(--page-width)) / 2 + var(--page-margin))) 5.25rem;
    padding-right: 4rem;
  }

  .hero--split .hero__media {
    min-height: 32rem;
    overflow: hidden;
  }

  .hero--split .hero__media img,
  .hero--split .hero__media svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__eyebrow {
    letter-spacing: 0.28em;
    margin-bottom: 1.375rem;
  }

  .hero__heading {
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1.02;
    letter-spacing: -0.015em;
    max-width: 12ch;
  }

  .hero__text {
    margin-top: 1.5rem;
    font-size: 1rem;
    line-height: 1.65;
    color: var(--color-text-muted);
    max-width: 25rem;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    margin-top: 2.125rem;
  }

  .hero--full-bleed {
    position: relative;
    display: flex;
    align-items: flex-end;
    min-height: 34rem;
    background: var(--color-foreground);
  }

  .hero__background {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .hero__background img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--color-foreground) 62%, transparent) 0%,
      color-mix(in srgb, var(--color-foreground) 20%, transparent) 46%,
      transparent 70%
    );
  }

  .hero--full-bleed .hero__content {
    position: relative;
    padding: 2.75rem max(3rem, calc((100vw - var(--page-width)) / 2 + var(--page-margin)));
    padding-bottom: 2.75rem;
  }

  .hero--full-bleed .hero__heading,
  .hero--full-bleed .hero__text {
    color: var(--color-background);
  }

  .hero--full-bleed .hero__eyebrow {
    color: color-mix(in srgb, var(--color-accent) 60%, var(--color-background));
  }

  .hero--full-bleed .hero__secondary-cta {
    color: var(--color-background);
    border-color: color-mix(in srgb, var(--color-background) 50%, transparent);
  }

  .hero--full-bleed .hero__secondary-cta:hover {
    color: var(--color-background);
    border-color: var(--color-background);
  }

  @media (max-width: 749px) {
    .hero--split {
      grid-template-columns: 1fr;
    }

    .hero--split .hero__content {
      padding: 3rem var(--page-margin);
      order: 2;
    }

    .hero--split .hero__media {
      min-height: 18rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.hero",
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "t:labels.layout",
      "options": [
        { "value": "hero--split", "label": "t:options.hero.split" },
        { "value": "hero--full-bleed", "label": "t:options.hero.full_bleed" }
      ],
      "default": "hero--split"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "New harvest · Ethiopia"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Notes from the origin."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "t:labels.text",
      "default": "Single-origin coffee, sourced transparently and roasted in small batches. Each lot documented — origin, process, altitude, harvest."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:labels.image"
    },
    {
      "type": "text",
      "id": "primary_cta_label",
      "label": "t:labels.primary_cta_label",
      "default": "Shop Reserve Roast"
    },
    {
      "type": "url",
      "id": "primary_cta_link",
      "label": "t:labels.primary_cta_link"
    },
    {
      "type": "text",
      "id": "secondary_cta_label",
      "label": "t:labels.secondary_cta_label",
      "default": "Explore origins"
    },
    {
      "type": "url",
      "id": "secondary_cta_link",
      "label": "t:labels.secondary_cta_link"
    }
  ],
  "presets": [{ "name": "t:general.hero" }],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
