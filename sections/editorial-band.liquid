<div class="editorial-band full-width">
  <div class="editorial-band__media">
    {% if section.settings.image %}
      {{ section.settings.image | image_url: width: 1400 | image_tag: loading: 'lazy' }}
    {% else %}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'editorial-band__placeholder' }}
    {% endif %}
  </div>

  <div class="editorial-band__content">
    {% if section.settings.eyebrow != blank %}
      <p class="eyebrow editorial-band__eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}

    <h2 class="editorial-band__quote">{{ section.settings.quote }}</h2>

    {% if section.settings.link_label != blank %}
      <a href="{{ section.settings.link | default: routes.root_url }}" class="text-link editorial-band__link">
        {{- section.settings.link_label }} →</a
      >
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .editorial-band {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: var(--color-foreground);
    color: var(--color-background);
  }

  .editorial-band__media {
    min-height: 24rem;
    overflow: hidden;
  }

  .editorial-band__media img,
  .editorial-band__media svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .editorial-band__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    padding: 4.5rem 4rem;
  }

  .editorial-band__eyebrow {
    letter-spacing: 0.28em;
    color: color-mix(in srgb, var(--color-accent) 55%, var(--color-background));
    margin-bottom: 1.25rem;
  }

  .editorial-band__quote {
    font-weight: 500;
    font-size: 2rem;
    line-height: 1.25;
    letter-spacing: -0.005em;
    max-width: 30ch;
  }

  .editorial-band__link {
    margin-top: 1.75rem;
    color: color-mix(in srgb, var(--color-accent) 55%, var(--color-background));
  }

  .editorial-band__link:hover {
    color: var(--color-background);
  }

  @media (max-width: 749px) {
    .editorial-band {
      grid-template-columns: 1fr;
    }

    .editorial-band__media {
      min-height: 16rem;
    }

    .editorial-band__content {
      padding: 3rem var(--page-margin);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.editorial_band",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "The Fieldnote"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "t:labels.quote",
      "default": "We publish what we know — the farm, the elevation, the process — and let the cup speak for itself."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:labels.image"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "t:labels.link_label",
      "default": "Read our sourcing notes"
    },
    {
      "type": "url",
      "id": "link",
      "label": "t:labels.link"
    }
  ],
  "presets": [{ "name": "t:general.editorial_band" }],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
